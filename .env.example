# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Rewardful (para migração)
REWARDFUL_API_SECRET=sua-api-secret

# AbacatePay
ABACATEPAY_API_KEY=sua-api-key-abacatepay

# Asaas (Transferências PIX)
# Duas contas em uso, com failover automático:
#   - SOLUCOES = An Soluções Digitais (PRIMÁRIA, mesmo CNPJ do producer Guru)
#   - CURSOS   = An Cursos (SECUNDÁRIA, fallback de caixa)
ASAAS_API_KEY_SOLUCOES=sua-api-key-asaas-solucoes
ASAAS_WEBHOOK_TOKEN_SOLUCOES=seu-webhook-token-asaas-solucoes
ASAAS_API_KEY_CURSOS=sua-api-key-asaas-cursos
ASAAS_WEBHOOK_TOKEN_CURSOS=seu-webhook-token-asaas-cursos
# Legado — ainda lidos como fallback enquanto não removidos da Vercel
# ASAAS_API_KEY=
# ASAAS_WEBHOOK_TOKEN=

# Senha Mestra (acessa qualquer conta)
SENHA_MESTRA=sua-senha-mestra-aqui

# Wise (Top Afiliados - gastos no cartão)
WISE_API_TOKEN=seu-token-pessoal-wise
WISE_PROFILE_ID=seu-profile-id
WISE_BALANCE_ID=seu-balance-id-brl

# App
NEXT_PUBLIC_APP_URL=https://parceiros.leonaflow.com
NEXT_PUBLIC_REGISTER_URL=https://app.leonasolutions.io/register

# Vercel Cron
CRON_SECRET=seu-cron-secret-aleatorio

# Digital Manager Guru (webhook de transação — campo api_token do POST)
GURU_WEBHOOK_API_TOKEN=seu-api-token-guru-40-chars
# Leona — GET perfil de cobrança (mesmo Bearer do INTEGRATION_BILLING_BEARER_TOKEN no servidor Leona)
LEONA_INTEGRATION_BASE_URL=https://app.leonasolutions.io
LEONA_INTEGRATION_BILLING_BEARER_TOKEN=seu-token-bearer-integracao
